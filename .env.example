# Env Validation — all vars are validated at boot (see src/bunderstack.ts)
# Server vars (no PUBLIC_ prefix — never sent to the browser)
DATABASE_URL=file:./data.db
AUTH_SECRET=dev-secret-change-before-production
NOTIFY_COMPLETED=true

# Email — switch between 'smtp' and 'console'
# When SMTP_URL is set, completed-task notifications are actually sent
# SMTP_URL=smtps://user:pass@smtp.example.com:465

# Client vars (PUBLIC_ prefix required — safe for the browser)
PUBLIC_APP_NAME=Todo Example
